  "keyFeatures": [
    "AI-powered code modernization using Groq inference",
    "Automatic PR creation with detailed AI-generated changelogs",
    "Smart fork detection and repository handling",
    "Real-time progress tracking via Supabase",
    "Parallel file processing with Modal containers",
    "GitHub OAuth authentication",
    "Support for JavaScript/TypeScript and Python",
    "GitButler-style PR descriptions with before/after comparisons"
  ],
  "publicApiSurface": [
    "POST /auth/github - GitHub OAuth authentication",
    "GET /auth/verify - Verify session token",
    "POST /update - Trigger repository modernization",
    "GET /health - API health check",
    "WebSocket /ws - Real-time progress updates"
